# --- Step 1: Node selection (top-6 empirical BEI) ----------------------------
# Assumes top6_empirical_bei is already defined as the 6 top empirical-partition
# bridge items used for the sentinel composite.
sentinel_items <- top6_empirical_bei

cat(glue("  Sentinel items: {paste(sentinel_items, collapse = ', ')}"), "\n")
cat(glue("  Labels: {paste(item_labels[sentinel_items], collapse = ', ')}"), "\n\n")

# --- Step 2: Sample splitting ------------------------------------------------
set.seed(2024)
deriv_idx <- sample(seq_len(nrow(items_df)), size = round(0.60 * nrow(items_df)))
valid_idx <- setdiff(seq_len(nrow(items_df)), deriv_idx)

deriv_data <- items_df[deriv_idx, , drop = FALSE]
valid_data <- items_df[valid_idx, , drop = FALSE]

cat(glue("  Derivation: n = {nrow(deriv_data)}, Validation: n = {nrow(valid_data)}"), "\n\n")

# --- Step 3: Score computation -----------------------------------------------
deriv_data$full_score     <- rowSums(deriv_data[, all_items, drop = FALSE], na.rm = FALSE)
valid_data$full_score     <- rowSums(valid_data[, all_items, drop = FALSE], na.rm = FALSE)
deriv_data$sentinel_score <- rowSums(deriv_data[, sentinel_items, drop = FALSE], na.rm = FALSE)
valid_data$sentinel_score <- rowSums(valid_data[, sentinel_items, drop = FALSE], na.rm = FALSE)

# --- Step 4: Internal proxy performance --------------------------------------
# Criterion validity in the manuscript should be described as INTERNAL PROXY
# performance, because the outcome is derived from the same 35-item instrument.

# (a) Variance explained in validation sample
lm_sent <- lm(full_score ~ sentinel_score, data = valid_data)
r2_sentinel <- summary(lm_sent)$r.squared
cat(glue("  Sentinel R² (validation): {round(r2_sentinel, 4)}"), "\n")

# (b) Internal high-burden proxy: T-score >= 63 based on pooled full-scale scores
pooled_scores <- c(deriv_data$full_score, valid_data$full_score)
full_mean <- mean(pooled_scores)
full_sd   <- sd(pooled_scores)

valid_data$t_score <- 50 + 10 * (valid_data$full_score - full_mean) / full_sd
valid_data$screen_positive <- as.integer(valid_data$t_score >= 63)

roc_sentinel <- pROC::roc(valid_data$screen_positive, valid_data$sentinel_score, quiet = TRUE)

cat("  Criterion validity (internal screening proxy):\n")
cat(glue("    AUC vs T-score >= 63 (high symptom burden): {round(pROC::auc(roc_sentinel), 3)}"), "\n")
cat("    (Note: this is internal proxy validation, not external clinical validation)\n\n")

