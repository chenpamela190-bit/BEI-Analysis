# ══════════════════════════════════════════════════════════════════════════════
# SUPPLEMENTARY TABLE S3 — PEARSON VS POLYCHORIC SENSITIVITY
# ══════════════════════════════════════════════════════════════════════════════

# Pearson objects from main analysis
adj_pearson <- adj_mat
bei_pearson <- bei_values_empirical[all_items]

# Polychoric correlation matrix
poly_out <- psych::polychoric(items_df[, all_items, drop = FALSE], correct = 0)
cor_poly <- poly_out$rho

# Polychoric network
adj_poly <- qgraph::EBICglasso(
  cor_poly,
  n = nrow(items_df),
  gamma = 0.5
)

# Empirical Walktrap partition for polychoric network
g_poly <- igraph::graph_from_adjacency_matrix(
  abs(adj_poly),
  mode = "undirected",
  weighted = TRUE,
  diag = FALSE
)

wt_poly <- igraph::cluster_walktrap(g_poly, steps = 4)
wt_poly_membership <- igraph::membership(wt_poly)
wt_poly_membership <- wt_poly_membership[all_items]

# Polychoric BEI
emp_comm_poly <- setNames(as.integer(wt_poly_membership), all_items)

bei_poly_obj <- networktools::bridge(
  adj_poly,
  communities = emp_comm_poly,
  useCommunities = "all"
)

bei_poly <- bei_poly_obj$`Bridge Expected Influence (1-step)`
bei_poly <- bei_poly[all_items]

# S3 statistics
edge_r <- cor(
  adj_pearson[upper.tri(adj_pearson)],
  adj_poly[upper.tri(adj_poly)],
  method = "pearson"
)

bei_rho <- cor(
  rank(-abs(bei_pearson)),
  rank(-abs(bei_poly)),
  method = "spearman"
)

top6_pearson <- names(sort(abs(bei_pearson), decreasing = TRUE))[1:6]
top6_poly <- names(sort(abs(bei_poly), decreasing = TRUE))[1:6]
top6_overlap <- length(intersect(top6_pearson, top6_poly))

table_s3 <- data.frame(
  Comparison = c(
    "Pearson vs polychoric edge weights",
    "Pearson vs polychoric BEI rankings",
    "Top-6 empirical BEI overlap"
  ),
  Statistic = c("Pearson r", "Spearman rho", "Shared nodes"),
  Value = c(round(edge_r, 3), round(bei_rho, 3), top6_overlap),
  stringsAsFactors = FALSE
)

print(table_s3)
knitr::kable(
  table_s3,
  caption = "Supplementary Table S3. Pearson vs polychoric sensitivity"
)

write.csv(table_s3, "TableS3_Pearson_vs_Polychoric_Sensitivity.csv", row.names = FALSE)
