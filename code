# ---------------------------------------------------------------------------
# Helper 1: node knockout
# ---------------------------------------------------------------------------
node_knockout <- function(data, items, target_node, gamma = 0.5,
                          baseline_S = NULL, cor_method = "cor_auto") {
  
  if (is.null(baseline_S)) {
    net_base <- estimateNetwork(
      data[, items], default = "EBICglasso",
      corMethod = cor_method, tuning = gamma,
      threshold = FALSE, verbose = FALSE
    )
    adj_base <- getWmat(net_base)
    baseline_S <- sum(abs(adj_base[upper.tri(adj_base)]))
  }
  
  remaining <- setdiff(items, target_node)
  
  net_ko <- estimateNetwork(
    data[, remaining], default = "EBICglasso",
    corMethod = cor_method, tuning = gamma,
    threshold = FALSE, verbose = FALSE
  )
  
  adj_ko <- getWmat(net_ko)
  S_ko   <- sum(abs(adj_ko[upper.tri(adj_ko)]))
  delta  <- (baseline_S - S_ko) / baseline_S * 100
  
  list(
    target_node        = target_node,
    baseline_S         = baseline_S,
    knockout_S         = S_ko,
    delta_connectivity = delta
  )
}

# ---------------------------------------------------------------------------
# Helper 2: compute EI consistently from adjacency matrix
# Use the SAME definition for both partitions
# ---------------------------------------------------------------------------
compute_ei <- function(adj_mat) {
  ei <- rowSums(adj_mat)
  names(ei) <- rownames(adj_mat)
  ei
}

# ---------------------------------------------------------------------------
# Helper 3: nearest-neighbor matching on EI
# same rule for both partitions
# ---------------------------------------------------------------------------
match_controls_by_ei <- function(target_nodes, ei_vals, all_items,
                                 tolerance = 0.10,
                                 without_replacement = TRUE,
                                 relax_tolerance = TRUE,
                                 relaxed_tolerance = 0.15) {
  
  control_pool <- setdiff(all_items, target_nodes)
  used_controls <- character(0)
  
  match_df <- data.frame(
    target_node   = character(0),
    target_ei     = numeric(0),
    control_node  = character(0),
    control_ei    = numeric(0),
    abs_diff      = numeric(0),
    tolerance_used = numeric(0),
    stringsAsFactors = FALSE
  )
  
  for (target in target_nodes) {
    target_ei <- ei_vals[target]
    
    available <- if (without_replacement) {
      setdiff(control_pool, used_controls)
    } else {
      control_pool
    }
    
    diffs <- abs(ei_vals[available] - target_ei)
    
    # First pass: strict tolerance
    eligible <- available[diffs <= tolerance]
    tol_used <- tolerance
    
    # Optional fallback: relaxed tolerance
    if (length(eligible) == 0 && relax_tolerance) {
      eligible <- available[diffs <= relaxed_tolerance]
      tol_used <- relaxed_tolerance
    }
    
    # Final fallback: nearest available control, even if outside tolerance
    if (length(eligible) == 0) {
      eligible <- available
      tol_used <- NA_real_
    }
    
    eligible_diffs <- abs(ei_vals[eligible] - target_ei)
    best_control <- eligible[which.min(eligible_diffs)]
    best_diff <- min(eligible_diffs)
    
    match_df <- rbind(
      match_df,
      data.frame(
        target_node    = target,
        target_ei      = unname(target_ei),
        control_node   = best_control,
        control_ei     = unname(ei_vals[best_control]),
        abs_diff       = unname(best_diff),
        tolerance_used = tol_used,
        stringsAsFactors = FALSE
      )
    )
    
    if (without_replacement) {
      used_controls <- c(used_controls, best_control)
    }
  }
  
  match_df
}

# ---------------------------------------------------------------------------
# Helper 4: run one full knockout comparison for one partition
# ---------------------------------------------------------------------------
run_knockout_comparison <- function(partition_name,
                                    target_nodes,
                                    data,
                                    all_items,
                                    adj_mat,
                                    item_labels,
                                    gamma = 0.5,
                                    cor_method = "cor_auto",
                                    tolerance = 0.10,
                                    without_replacement = TRUE,
                                    n_perm = 5000) {
  
  cat(strrep("-", 78), "\n")
  cat(glue("  {partition_name} partition\n"))
  cat(strrep("-", 78), "\n")
  
  # Baseline S from full network adjacency already estimated for this dataset
  S_baseline <- sum(abs(adj_mat[upper.tri(adj_mat)]))
  cat(glue("  Baseline global connectivity (S): {round(S_baseline, 3)}\n"))
  
  # EI for matching
  ei_vals <- compute_ei(adj_mat)
  
  cat(glue("  Top-6 bridge nodes: {paste(target_nodes, collapse = ', ')}\n"))
  cat(glue("  Labels: {paste(item_labels[target_nodes], collapse = ', ')}\n\n"))
  
  # Match controls
  cat("  Matching non-bridge controls on Expected Influence...\n")
  match_df <- match_controls_by_ei(
    target_nodes = target_nodes,
    ei_vals = ei_vals,
    all_items = all_items,
    tolerance = tolerance,
    without_replacement = without_replacement,
    relax_tolerance = TRUE,
    relaxed_tolerance = 0.15
  )
  
  for (i in seq_len(nrow(match_df))) {
    cat(glue(
      "    {match_df$target_node[i]} (EI = {round(match_df$target_ei[i], 3)}) ",
      "↔ {match_df$control_node[i]} (EI = {round(match_df$control_ei[i], 3)}, ",
      "Δ = {round(match_df$abs_diff[i], 3)})"
    ), "\n")
  }
  cat("\n")
  
  bridge_nodes <- match_df$target_node
  control_nodes <- match_df$control_node
  
  knockout_targets <- c(bridge_nodes, control_nodes)
  knockout_group <- c(rep("Bridge", length(bridge_nodes)),
                      rep("Control", length(control_nodes)))
  
  cat(glue("  Running knockout simulations ({length(knockout_targets)} nodes)...\n"))
  
  ko_results <- vector("list", length(knockout_targets))
  
  for (i in seq_along(knockout_targets)) {
    node <- knockout_targets[i]
    cat(glue("    [{i}/{length(knockout_targets)}] {node} ({item_labels[node]})..."))
    
    result <- tryCatch(
      {
        node_knockout(
          data = data,
          items = all_items,
          target_node = node,
          gamma = gamma,
          baseline_S = S_baseline,
          cor_method = cor_method
        )
      },
      error = function(e) {
        cat(glue(" FAILED: {e$message}\n"))
        return(NULL)
      }
    )
    
    if (!is.null(result)) {
      ko_results[[i]] <- result
      cat(glue(" Δ = {round(result$delta_connectivity, 2)}%\n"))
    } else {
      ko_results[[i]] <- NA
    }
  }
  cat("\n")
  
  keep_idx <- !is.na(ko_results)
  ko_results_clean <- ko_results[keep_idx]
  knockout_group_clean <- knockout_group[keep_idx]
  
  ko_df <- do.call(rbind, lapply(seq_along(ko_results_clean), function(i) {
    data.frame(
      Partition = partition_name,
      Node      = ko_results_clean[[i]]$target_node,
      Label     = item_labels[ko_results_clean[[i]]$target_node],
      Group     = knockout_group_clean[i],
      Delta     = ko_results_clean[[i]]$delta_connectivity,
      stringsAsFactors = FALSE
    )
  }))
  
  bridge_delta <- ko_df$Delta[ko_df$Group == "Bridge"]
  control_delta <- ko_df$Delta[ko_df$Group == "Control"]
  
  obs_diff <- mean(bridge_delta) - mean(control_delta)
  
  t_result <- t.test(bridge_delta, control_delta, var.equal = FALSE)
  d_ko <- effectsize::cohens_d(bridge_delta, control_delta)
  
  all_deltas <- c(bridge_delta, control_delta)
  perm_diffs <- replicate(n_perm, {
    perm_idx <- sample(seq_along(all_deltas), length(bridge_delta))
    mean(all_deltas[perm_idx]) - mean(all_deltas[-perm_idx])
  })
  perm_p <- mean(abs(perm_diffs) >= abs(obs_diff))
  
  summary_df <- data.frame(
    Partition = partition_name,
    Bridge_Mean_Delta = mean(bridge_delta),
    Bridge_SD_Delta = sd(bridge_delta),
    Control_Mean_Delta = mean(control_delta),
    Control_SD_Delta = sd(control_delta),
    Difference = obs_diff,
    t_value = unname(t_result$statistic),
    p_value = t_result$p.value,
    Permutation_p = perm_p,
    Cohens_d = d_ko$Cohens_d,
    stringsAsFactors = FALSE
  )
  
  cat(glue("  Mean ΔConnectivity — Bridge: {round(mean(bridge_delta), 2)}% ",
           "(SD = {round(sd(bridge_delta), 2)}), ",
           "Control: {round(mean(control_delta), 2)}% ",
           "(SD = {round(sd(control_delta), 2)})\n"))
  cat(glue("  Difference: {round(obs_diff, 2)} percentage points\n"))
  cat(glue("  t = {round(t_result$statistic, 3)}, ",
           "p = {format.pval(t_result$p.value, digits = 3)}\n"))
  cat(glue("  Permutation p = {round(perm_p, 4)}\n"))
  cat(glue("  Cohen's d = {round(d_ko$Cohens_d, 3)}\n\n"))
  
  list(
    matches = match_df,
    ko_df = ko_df,
    summary = summary_df
  )
}

