# 9.  HYPOTHESIS 5 — TEMPORAL INVARIANCE (Network Comparison Test)
# ══════════════════════════════════════════════════════════════════════════════
cat(strrep("=", 78), "\n")
cat("  HYPOTHESIS 5: Temporal Invariance (NCT)\n")
cat(strrep("=", 78), "\n\n")

if (all(is.na(dat$cohort_year))) {
  cat("  ⚠ Skipping H5: No cohort_year variable available.\n\n")
  h5_support <- NA
} else {
  
  dat[, all_items] <- lapply(dat[, all_items], function(x) as.numeric(as.character(x)))
  
  dat$period <- dplyr::case_when(
    dat$cohort_year %in% c(2019, 2020) ~ "Pre-pandemic",
    dat$cohort_year %in% c(2021, 2022) ~ "Acute",
    dat$cohort_year %in% c(2023, 2024) ~ "Post-acute",
    TRUE ~ NA_character_
  )
  
  period_ns <- table(dat$period, useNA = "ifany")
  cat("  Period sample sizes:\n")
  print(period_ns)
  cat("\n")
  
  dat_pre  <- dat %>% filter(period == "Pre-pandemic") %>% select(all_of(all_items)) %>% drop_na()
  dat_acu  <- dat %>% filter(period == "Acute")        %>% select(all_of(all_items)) %>% drop_na()
  dat_post <- dat %>% filter(period == "Post-acute")   %>% select(all_of(all_items)) %>% drop_na()
  
  NCT_SUBSAMPLE <- NULL
  NCT_ITER      <- 2500
  
  subsample_for_nct <- function(df, max_n) {
    if (is.null(max_n) || nrow(df) <= max_n) return(df)
    df[sample(nrow(df), max_n), ]
  }
  
  dat_pre_nct  <- subsample_for_nct(dat_pre,  NCT_SUBSAMPLE)
  dat_acu_nct  <- subsample_for_nct(dat_acu,  NCT_SUBSAMPLE)
  dat_post_nct <- subsample_for_nct(dat_post, NCT_SUBSAMPLE)
  
  cat(glue("  NCT config: {NCT_ITER} permutations",
           "{ifelse(!is.null(NCT_SUBSAMPLE), paste0(', capped at n = ', NCT_SUBSAMPLE, ' per group'), ', full samples')}"), "\n")
  cat("  ⚠ This will take several hours. Starting...\n\n")
  
  # [FIX-E] Error handling for NCT calls
  error_log_nct <- file("nct_errors.log", "w")
  
  nct_1 <- tryCatch(
    {
      cat("  NCT 1/3: Pre-pandemic vs Acute...\n")
      NCT(dat_pre_nct, dat_acu_nct,
          it = NCT_ITER, binary.data = FALSE, paired = FALSE,
          weighted = TRUE, test.edges = TRUE, edges = "all",
          progressbar = TRUE, p.adjust.methods = "BH", gamma = 0.5)
    },
    error = function(e) {
      msg <- glue("  ERROR in NCT 1 (Pre vs Acute): {e$message}")
      cat(msg, "\n")
      writeLines(msg, con = error_log_nct)
      return(NULL)
    }
  )
  
  nct_2 <- tryCatch(
    {
      cat("  NCT 2/3: Pre-pandemic vs Post-acute...\n")
      NCT(dat_pre_nct, dat_post_nct,
          it = NCT_ITER, binary.data = FALSE, paired = FALSE,
          weighted = TRUE, test.edges = TRUE, edges = "all",
          progressbar = TRUE, p.adjust.methods = "BH", gamma = 0.5)
    },
    error = function(e) {
      msg <- glue("  ERROR in NCT 2 (Pre vs Post): {e$message}")
      cat(msg, "\n")
      writeLines(msg, con = error_log_nct)
      return(NULL)
    }
  )
  
  nct_3 <- tryCatch(
    {
      cat("  NCT 3/3: Acute vs Post-acute...\n")
      NCT(dat_acu_nct, dat_post_nct,
          it = NCT_ITER, binary.data = FALSE, paired = FALSE,
          weighted = TRUE, test.edges = TRUE, edges = "all",
          progressbar = TRUE, p.adjust.methods = "BH", gamma = 0.5)
    },
    error = function(e) {
      msg <- glue("  ERROR in NCT 3 (Acute vs Post): {e$message}")
      cat(msg, "\n")
      writeLines(msg, con = error_log_nct)
      return(NULL)
    }
  )
  
  close(error_log_nct)
  
  # Check for NCT failures
  if (is.null(nct_1) | is.null(nct_2) | is.null(nct_3)) {
    cat("\n  ⚠ One or more NCT comparisons failed. See nct_errors.log.\n")
    cat("  Skipping H5 decision due to incomplete data.\n\n")
    h5_support <- NA
  } else {
    
    # NCT succeeded; proceed with community analysis
    cat("\n  Cross-period community detection...\n")
    
    estimate_walktrap <- function(df) {
      net_tmp <- estimateNetwork(df, default = "EBICglasso",
                                 corMethod = "cor_auto", tuning = 0.5,
                                 verbose = FALSE)
      g_tmp <- graph_from_adjacency_matrix(abs(getWmat(net_tmp)),
                                           mode = "undirected",
                                           weighted = TRUE, diag = FALSE)
      membership(cluster_walktrap(g_tmp, steps = 4))
    }
    
    wt_pre  <- estimate_walktrap(dat_pre)
    wt_acu  <- estimate_walktrap(dat_acu)
    wt_post <- estimate_walktrap(dat_post)
    
    # [FIX-H] Check community count consistency across periods
    n_comm_pre  <- max(wt_pre)
    n_comm_acu  <- max(wt_acu)
    n_comm_post <- max(wt_post)
    
    cat(glue("  Community counts: Pre = {n_comm_pre}, Acute = {n_comm_acu}, Post = {n_comm_post}\n\n"))
    
    if (!(n_comm_pre == n_comm_acu & n_comm_acu == n_comm_post)) {
      cat(glue("  ⚠ WARNING: Community count differs across periods.\n"))
      cat(glue("    This may reduce interpretability of ARI comparisons.\n"))
      cat(glue("    Proceeding with caution; see interpretation notes below.\n\n"))
    }
    
    ari_pre_acu  <- mclust::adjustedRandIndex(wt_pre, wt_acu)
    ari_pre_post <- mclust::adjustedRandIndex(wt_pre, wt_post)
    ari_acu_post <- mclust::adjustedRandIndex(wt_acu, wt_post)
    
    # Extract NCT structure p-values
    p_nct_1 <- as.numeric(nct_1$nwinv.pval)
    p_nct_2 <- as.numeric(nct_2$nwinv.pval)
    p_nct_3 <- as.numeric(nct_3$nwinv.pval)
    
    # [FIX-B] Apply Benjamini–Hochberg correction across three comparisons
    p_vals_struct  <- c(p_nct_1, p_nct_2, p_nct_3)
    p_adj_struct   <- p.adjust(p_vals_struct, method = "BH")
    p_nct_1_adj    <- p_adj_struct[1]
    p_nct_2_adj    <- p_adj_struct[2]
    p_nct_3_adj    <- p_adj_struct[3]
    
    cat("\n  Network structure invariance (NCT):\n")
    cat(glue("    Pre-Pandemic vs Acute:   p(raw) = {round(p_nct_1, 4)}, p(BH-adj) = {round(p_nct_1_adj, 4)}"), "\n")
    cat(glue("    Pre-Pandemic vs Post:    p(raw) = {round(p_nct_2, 4)}, p(BH-adj) = {round(p_nct_2_adj, 4)}"), "\n")
    cat(glue("    Acute vs Post:           p(raw) = {round(p_nct_3, 4)}, p(BH-adj) = {round(p_nct_3_adj, 4)}"), "\n\n")
    
    cat("  Community stability (ARI):\n")
    cat(glue("    ARI (Pre vs Acute):  {round(ari_pre_acu, 3)}"), "\n")
    cat(glue("    ARI (Pre vs Post):   {round(ari_pre_post, 3)}"), "\n")
    cat(glue("    ARI (Acute vs Post): {round(ari_acu_post, 3)}"), "\n\n")
    
    # [FIX-B] Decision rule using BH-adjusted p-values
    struct_invariant <- (p_nct_1_adj > 0.05) & (p_nct_2_adj > 0.05) & (p_nct_3_adj > 0.05)
    comm_stable      <- (ari_pre_acu > 0.80) & (ari_pre_post > 0.80) & (ari_acu_post > 0.80)
    
    h5_support <- struct_invariant & comm_stable
    
    cat(glue("  Structure invariant (all p_adj > .05): {struct_invariant}"), "\n")
    cat(glue("  Community stable (all ARI > .80):      {comm_stable}"), "\n\n")
    
    if (!(n_comm_pre == n_comm_acu & n_comm_acu == n_comm_post)) {
      cat("  ⚠ INTERPRETATION NOTE:\n")
      cat("    Community counts differ across periods, which may indicate genuine\n")
      cat("    temporal shifts in symptom clustering. ARI > 0.80 suggests some\n")
      cat("    invariance despite structural changes. See sensitivity analysis.\n\n")
    }
    
    cat(glue("  ▶ H5 DECISION: {ifelse(h5_support, 'YES — Temporal Invariance SUPPORTED ✓', 'NO — Falsified ✗')}"), "\n\n")
  }
}





