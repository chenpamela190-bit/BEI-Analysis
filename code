run_qc_sensitivity <- function(df_items, sample_name, all_items, subscale_membership) {
  
  # 1. Estimate network exactly as in main analysis
  net_tmp <- estimateNetwork(
    df_items,
    default   = "EBICglasso",
    corMethod = "cor_auto",
    tuning    = 0.5,
    threshold = FALSE,
    verbose   = FALSE
  )
  
  adj_tmp <- getWmat(net_tmp)
  
  # 2. Empirical partition: Walktrap
  g_tmp <- graph_from_adjacency_matrix(
    abs(adj_tmp),
    mode = "undirected",
    weighted = TRUE,
    diag = FALSE
  )
  
  wt_tmp <- cluster_walktrap(g_tmp, steps = 4)
  wt_membership_tmp <- membership(wt_tmp)
  
  # 3. A priori 3-subscale partition
  apriori_comm_vec <- setNames(
    c(rep(1, 12), rep(2, 13), rep(3, 10)),
    all_items
  )
  
  scl_mem_num <- as.numeric(factor(
    subscale_membership[all_items],
    levels = c("Somatization", "Depression", "Anxiety")
  ))
  
  # 4. ARI: empirical vs a priori
  ari_tmp <- mclust::adjustedRandIndex(wt_membership_tmp, scl_mem_num)
  
  # 5. BEI under empirical partition
  emp_comm_vec <- setNames(as.integer(wt_membership_tmp), all_items)
  
  bei_emp_obj <- networktools::bridge(
    adj_tmp,
    communities    = emp_comm_vec,
    useCommunities = "all"
  )
  bei_emp <- bei_emp_obj$`Bridge Expected Influence (1-step)`
  names(bei_emp) <- all_items
  
  # 6. BEI under a priori partition
  bei_apr_obj <- networktools::bridge(
    adj_tmp,
    communities    = apriori_comm_vec,
    useCommunities = "all"
  )
  bei_apr <- bei_apr_obj$`Bridge Expected Influence (1-step)`
  names(bei_apr) <- all_items
  
  # 7. Rank correlation across partitions
  rho_tmp <- cor(
    rank(-abs(bei_emp[all_items])),
    rank(-abs(bei_apr[all_items])),
    method = "spearman"
  )
  
  # 8. Top-6 overlap across partitions
  top6_emp <- names(sort(abs(bei_emp[all_items]), decreasing = TRUE))[1:6]
  top6_apr <- names(sort(abs(bei_apr[all_items]), decreasing = TRUE))[1:6]
  overlap_tmp <- length(intersect(top6_emp, top6_apr))
  
  # 9. Output row
  out <- data.frame(
    Sample = sample_name,
    N = nrow(df_items),
    Empirical_communities = max(wt_membership_tmp),
    ARI_vs_subscale = round(ari_tmp, 2),
    BEI_rank_correlation_rho = round(rho_tmp, 2),
    Top6_overlap = overlap_tmp,
    stringsAsFactors = FALSE
  )
  
  return(out)
}

