# QC FILTERING FUNCTION: Three-stage quality control
# ═══════════════════════════════════════════════════════════════════════════════

filter_data <- function(raw, all_items, long_thr = 15, mahal_alpha = NULL, robust = TRUE) {
  
  # Stage 1: Longstring detection
  item_subset <- raw[, all_items, drop = FALSE]
  
  # Count consecutive identical responses per row
  longstring_count <- apply(item_subset, 1, function(row) {
    if (all(is.na(row))) return(0)
    max_run <- 1
    current_run <- 1
    for (i in 2:length(row)) {
      if (!is.na(row[i]) && !is.na(row[i-1]) && row[i] == row[i-1]) {
        current_run <- current_run + 1
        max_run <- max(max_run, current_run)
      } else {
        current_run <- 1
      }
    }
    return(max_run)
  })
  
  idx_longstring <- longstring_count >= long_thr
  dat_after_long <- raw[!idx_longstring, ]
  
  # Stage 2: Mahalanobis distance (optional)
  if (is.null(mahal_alpha)) {
    # No Mahalanobis filtering
    idx_mahal <- rep(FALSE, nrow(dat_after_long))
  } else {
    item_data <- dat_after_long[, all_items, drop = FALSE]
    
    # Attempt robust covariance
    cov_obj <- NULL
    if (robust) {
      tryCatch({
        if (requireNamespace("robustbase", quietly = TRUE)) {
          cov_obj <- robustbase::covMcd(item_data, alpha = 0.75)
        } else if (requireNamespace("MASS", quietly = TRUE)) {
          cov_obj <- MASS::cov.rob(item_data, method = "mcd")
        }
      }, error = function(e) {
        cat("WARNING_ROBUST_FALLBACK\n")
        cov_obj <<- NULL
      })
    }
    
    # Fallback to classical covariance
    if (is.null(cov_obj)) {
      mu <- colMeans(item_data, na.rm = TRUE)
      Sigma <- cov(item_data, use = "complete.obs")
      
      # Check singularity
      if (det(Sigma) < 1e-10) {
        cat("WARNING_COV_SINGULAR_RIDGE\n")
        Sigma <- Sigma + diag(ncol(Sigma)) * 0.01
      }
    } else {
      mu <- if (inherits(cov_obj, "covMcd")) cov_obj$center else cov_obj$center
      Sigma <- if (inherits(cov_obj, "covMcd")) cov_obj$cov else cov_obj$cov
    }
    
    # Compute Mahalanobis distance
    X_centered <- sweep(item_data, 2, mu)
    mahal_dist <- mahalanobis(X_centered, center = FALSE, cov = Sigma)
    
    # Critical value for chi-squared
    chi2_crit <- qchisq(1 - mahal_alpha, df = length(all_items))
    idx_mahal <- mahal_dist > chi2_crit
  }
  
  dat_final <- dat_after_long[!idx_mahal, ]
  
  return(list(
    data = dat_final,
    N_original = nrow(raw),
    N_after_long = nrow(dat_after_long),
    N_final = nrow(dat_final),
    idx_longstring = idx_longstring,
    idx_mahal = idx_mahal
  ))
}
